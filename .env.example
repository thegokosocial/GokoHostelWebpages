# Self Check-in & Admin - Google Integration
#
# 1. Create a Google Cloud project: https://console.cloud.google.com
# 2. Enable Google Sheets API, Google Drive API, and Cloud Vision API
# 3. Create a Service Account and download the JSON key
# 4. Share your Google Sheet with the service account email (editor access)
# 5. Create a Google Drive folder for ID uploads
# 6. Create OAuth 2.0 Desktop credentials for Drive uploads
# 7. Run: node scripts/get-drive-token.js to get refresh token

# Service Account JSON key (entire JSON on one line)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Google Sheet ID (from URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit)
# Monthly tabs (e.g. MAY-2026) are auto-created
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Google Drive folder ID for ID uploads (monthly subfolders auto-created)
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# OAuth 2.0 credentials for Drive file uploads (Desktop app type)
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_OAUTH_REFRESH_TOKEN=your_refresh_token_here

# Admin password (full access: view, add, delete entries + Drive files)
ADMIN_PASSWORD=your_admin_password_here

# Manager password (can view and add entries, cannot delete)
MANAGER_PASSWORD=your_manager_password_here
